{
  "version": "4.3.0.26135",
  "description": "Senzing SDK for Windows",
  "homepage": "https://senzing.com/senzing-api/",
  "license": {
    "identifier": "Proprietary",
    "url": "https://senzing.com/software-license-agreement/"
  },
  "notes": [
    "WARNING: Preview Release - Unsupported",
    "This is a preview release. It is provided as-is with no warranty and is not supported.",
    "",
    "Senzing SDK has been installed.",
    "",
    "Environment variables have been configured:",
    "  SENZING_DIR: $dir\\er",
    "  PATH: $dir\\er\\lib (added)",
    "",
    "To verify installation:",
    "  echo $env:SENZING_DIR"
  ],
  "extract_dir": "senzing",
  "architecture": {
    "64bit": {
      "url": "https://senzing-production-win.s3.amazonaws.com/SenzingSDK_4.3.0.26135.zip",
      "hash": "fa5f68dfafada2a952c478f4cefa95ed5c95b0af1608da6ca393475eb568c206"
    }
  },
  "pre_install": [
    "$eulaUrl = 'https://senzing.com/software-license-agreement/'",
    "",
    "# Check if EULA has been accepted",
    "$envAccepted = $env:SENZING_ACCEPT_EULA",
    "$configAccepted = scoop config SENZING_ACCEPT_EULA",
    "",
    "$acceptValue = 'I_ACCEPT_THE_SENZING_EULA'",
    "if ($envAccepted -ieq $acceptValue -or $configAccepted -ieq $acceptValue) {",
    "    Write-Host 'ENVIRONMENT SET TO ACKNOWLEDGE ACCEPTANCE of the Senzing EULA at https://senzing.com/end-user-license-agreement' -ForegroundColor Green",
    "} else {",
    "    Write-Host ''",
    "    Write-Host 'Senzing SDK requires acceptance of the End User License Agreement (EULA).' -ForegroundColor Yellow",
    "    Write-Host \"EULA: $eulaUrl\" -ForegroundColor Cyan",
    "    Write-Host ''",
    "    Write-Host 'To accept the EULA, you can:' -ForegroundColor Yellow",
    "    Write-Host '  1. Set environment variable: $env:SENZING_ACCEPT_EULA = \"I_ACCEPT_THE_SENZING_EULA\"' -ForegroundColor Gray",
    "    Write-Host '  2. Set scoop config: scoop config SENZING_ACCEPT_EULA I_ACCEPT_THE_SENZING_EULA' -ForegroundColor Gray",
    "    Write-Host ''",
    "    $response = Read-Host 'Do you accept the Senzing EULA? (yes/no)'",
    "    if ($response -inotin @('I_ACCEPT_THE_SENZING_EULA', 'yes', 'y', '1')) {",
    "        Remove-Item -Path $dir -Recurse -Force -ErrorAction SilentlyContinue",
    "        throw 'Installation cancelled: EULA not accepted'",
    "    }",
    "}"
  ],
  "env_add_path": "er\\lib",
  "env_set": {
    "SENZING_DIR": "$dir\\er"
  },
  "checkver": {
    "url": "https://senzing-production-win.s3.amazonaws.com/",
    "regex": "SenzingSDK_([\\d.]+)\\.zip"
  },
  "autoupdate": {
    "extract_dir": "senzing",
    "architecture": {
      "64bit": {
        "url": "https://senzing-production-win.s3.amazonaws.com/SenzingSDK_4.3.0.26135.zip"
      }
    }
  }
}
